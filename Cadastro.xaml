<Window x:Class="CRUD.Cadastro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Cadastro" Height="530" Width="400">
    <Grid>
        <Border Width="320" Padding="30" Background="White" CornerRadius="10" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Criar Conta" FontSize="26" FontWeight="Bold" Foreground="#2F3640" Margin="0,0,0,5"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Preencha os dados abaixo" FontSize="12" Foreground="#7F8FA6" Margin="0,0,0,25"
                           HorizontalAlignment="Center" />

                <TextBlock Text="Nome" FontSize="12" FontWeight="SemiBold" Foreground="#353B48" Margin="0,0,0,5" />
                <TextBox x:Name="txtNome" Height="35" VerticalContentAlignment="Center" Padding="5,0"
                         Margin="0,0,0,15" />

                <TextBlock Text="Usuário" FontSize="12" FontWeight="SemiBold" Foreground="#353B48" Margin="0,0,0,5" />
                <TextBox x:Name="txtUsername" Height="35" VerticalContentAlignment="Center" Padding="5,0"
                         Margin="0,0,0,15" />

                <TextBlock Text="E-mail" FontSize="12" FontWeight="SemiBold" Foreground="#353B48" Margin="0,0,0,5" />
                <TextBox x:Name="txtEmail" Height="35" VerticalContentAlignment="Center" Padding="5,0"
                         Margin="0,0,0,15" />

                <TextBlock Text="Senha" FontSize="12" FontWeight="SemiBold" Foreground="#353B48" Margin="0,0,0,5" />
                <PasswordBox x:Name="txtSenha" Height="35" VerticalContentAlignment="Center" Padding="5,0"
                             Margin="0,0,0,25" />

                <Button x:Name="btnCadastrar" Content="Cadastrar" Height="40" Background="#448AFF" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Click="BtnCadastrar_OnClick">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5" />
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>