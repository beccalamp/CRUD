<Window x:Class="CRUD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">
    <Grid
        VerticalAlignment="Center" HorizontalAlignment="Center">
        <!-- Cartão de Login com Sombra -->
        <Border Width="320" Padding="30" Background="White" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>

            <StackPanel>
                <!-- Título -->
                <TextBlock Text="Bem-vindo" FontSize="26" FontWeight="Bold" Foreground="#2F3640" Margin="0,0,0,5"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Faça login para continuar" FontSize="12" Foreground="#7F8FA6" Margin="0,0,0,25"
                           HorizontalAlignment="Center" />

                <!-- Campo de Usuário -->
                <TextBlock Text="Usuário" FontSize="12" FontWeight="SemiBold" Foreground="#353B48" Margin="0,0,0,5" />
                <TextBox Name="txtUsuario" Height="35" VerticalContentAlignment="Center" Padding="5,0"
                         Margin="0,0,0,15" />

                <!-- Campo de Senha -->
                <TextBlock Text="Senha" FontSize="12" FontWeight="SemiBold" Foreground="#353B48" Margin="0,0,0,5" />
                <PasswordBox Name="txtSenha" Height="35" VerticalContentAlignment="Center" Padding="5,0"
                             Margin="0,0,0,25" />

                <!-- Botão Entrar -->
                <Button Name="btnEntrar" Content="Entrar" Height="40" Background="#448AFF" Foreground="White"
                        FontWeight="Bold" BorderThickness="0" Margin="0,0,0,15" Click="BtnEntrar_OnClick">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5" />
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Botão Cadastrar -->
                <Button Name="btnCadastrar" Content="Não tem uma conta? Cadastre-se" Background="Transparent"
                        Foreground="#448AFF" BorderThickness="0" Cursor="Hand" Click="BtnCadastrar_OnClick" />
            </StackPanel>
        </Border>
    </Grid>
</Window>