<Window x:Class="CRUD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRUD"
        mc:Ignorable="d"
        Title="MainWindow" Height="350" Width="400">
    <Grid>
<StackPanel Margin="20" VerticalAlignment="Center">
    <TextBlock Text="Nome:" Margin="0,0,0,2" />
    <TextBox x:Name="txtNome" Height="30" Margin="0,0,0,10" Padding="5" />
    
    <TextBlock Text="Username:" Margin="0,0,0,2" />
    <TextBox x:Name="txtUsername" Height="30" Margin="0,0,0,10" Padding="5" />
    
    <TextBlock Text="Email:" Margin="0,0,0,2" />
    <TextBox x:Name="txtEmail" Height="30" Margin="0,0,0,10" Padding="5" /> 
    
    <TextBlock Text="Senha:" Margin="0,0,0,2" />
    <PasswordBox x:Name="txtSenha" Height="30" Margin="0,0,0,15" Padding="5" />
    
    <Button x:Name="btnCadastrar" Content="Cadastrar" Height="35"
            Click="BtnCadastrar_OnClick" Background="CornflowerBlue" Foreground="White"/>
    
</StackPanel>
    </Grid>
</Window>
