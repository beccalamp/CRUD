<Window x:Class="CRUD.NovaPostagem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Nova Postagem"
        Height="450"
        Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" 
              Name="GridPostagem" 
              Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0"
                     Padding="4"
                     FontSize="16"
                     MaxLength="140"
                     MaxLines="6"
                     MinHeight="180"
                     TextWrapping="Wrap"
                     x:Name="TbConteudo"
                     TextChanged="TbConteudo_OnTextChanged">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5" />
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <Label Grid.Row="1" 
                   Content="0/140"
                   HorizontalAlignment="Right"
                   FontSize="12"
                   FontWeight="Light"
                   x:Name="lblCaracteresMax"/>
        </Grid>
        <Button Grid.Row="2"
                Background="#2563EB"
                Foreground="White"
                Content="Postar"
                FontSize="20"
                FontWeight="Bold"
                Margin="8"
                Padding="8"
                Click="BtnPostar_Onclick"
                IsDefault="True"
                ToolTip="A postagem só pode ser feita se o campo for preenchido!"
                >
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5" />
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>