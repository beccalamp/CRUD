<Window x:Class="CRUD.Feed"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:modelos="clr-namespace:CRUD.Modelos"
        Title="Mini Rede Social" Height="600" Width="500"
        Background="#F5F5F5" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <TextBlock Text="Meu Feed"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"
                       Foreground="#111827" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <ItemsControl x:Name="ItemsControlFeed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type modelos:Postagem}">
                            <Border Background="#FFFFFF"
                                    CornerRadius="12"
                                    Padding="16"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.05" Color="#000000" />
                                </Border.Effect>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Usuario.Nome}"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="#111827"
                                                   Margin="0,0,6,0" />

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Usuario.Username}"
                                                   Foreground="#6B7280"
                                                   FontSize="14"
                                                   Margin="0,0,6,0" />

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Postado_em, StringFormat='dd MMM - HH:mm'}"
                                                   Foreground="#6B7280" 
                                                   HorizontalAlignment="Right"
                                                   FontSize="14" />
                                    </Grid>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding conteudo}"
                                               TextWrapping="Wrap"
                                               FontSize="15"
                                               Foreground="#374151"
                                               LineHeight="20"
                                               Margin="0,0,0,12" />

                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                        <Button Content="❤️ Curtir"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#EF4444"
                                                FontWeight="SemiBold"
                                                FontSize="14"
                                                Cursor="Hand"
                                                Padding="0,4,8,4" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>