<Window x:Class="CRUD.Feed"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:modelos="clr-namespace:CRUD.Modelos"
        xmlns:utils="clr-namespace:CRUD.Utils"
        mc:Ignorable="d"
        Title="Feed" Height="680" Width="700"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="BotaoSemBorda" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <BooleanToVisibilityConverter x:Key="ConverterSuaPostagem"/>
    </Window.Resources>
    <Window.DataContext>
        <utils:FeedViewModel />
    </Window.DataContext>

    <Grid>
        <Border Background="White"
                CornerRadius="8"
                Padding="30"
                Width="420"
                Height="600"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Feed Social"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#111827"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <ItemsControl x:Name="ItemsControlFeed" ItemsSource="{Binding Postagens}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type modelos:Postagem}">
                                    <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Margin="0,0,0,20"
                                            Padding="0,0,0,15">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,10">
                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                                    <TextBlock Text="{Binding Usuario.Nome}"
                                                               FontWeight="Bold"
                                                               FontSize="14"
                                                               Foreground="#111827" />
                                                    <TextBlock Text="{Binding Usuario.Username, StringFormat='@{0}' }"
                                                               Foreground="#374151"
                                                               FontSize="13"
                                                               Margin="5,0,0,0"
                                                               Opacity="0.7" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding PostadoEm, StringFormat='dd MMM - HH:mm'}"
                                                           Foreground="#374151"
                                                           FontSize="12"
                                                           Opacity="0.5"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>

                                            <TextBlock
                                                Text="{Binding Conteudo}"
                                                TextWrapping="Wrap"
                                                FontSize="14"
                                                Foreground="#374151"
                                                Margin="0,0,0,15" />

                                            <StackPanel Orientation="Horizontal">

                                                <Button Content="❤️ Curtir"
                                                        Height="35"
                                                        Width="100"
                                                        HorizontalAlignment="Left"
                                                        FontWeight="Bold"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Click="BtnCurtir_OnClick"
                                                        Tag="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Setter Property="Foreground" Value="#2563EB" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FoiCurtido}"
                                                                             Value="True">
                                                                    <Setter Property="Foreground" Value="#FF0000" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <TextBlock VerticalAlignment="Center"
                                                           Margin="8,0"
                                                           Text="{Binding Curtidas, StringFormat='{}{0} curtidas'}" />


                                                <StackPanel Orientation="Horizontal" Visibility="{Binding SuaPostagem, Converter={StaticResource ConverterSuaPostagem}}">
                                                    <!-- Editar -->
                                                    <Button Background="Transparent"
                                                            Style="{StaticResource BotaoSemBorda}"
                                                            Margin="4,0"
                                                            Click="BtnEditarPostagem_OnClick"
                                                            Tag="{Binding Id}">
                                                        <Path
                                                            Data="M200-200h57l391-391-57-57-391 391v57Zm-80 80v-170l528-527q12-11 26.5-17t30.5-6q16 0 31 6t26 18l55 56q12 11 17.5 26t5.5 30q0 16-5.5 30.5T817-647L290-120H120Zm640-584-56-56 56 56Zm-141 85-28-29 57 57-29-28Z"
                                                            Width="24"
                                                            Height="24"
                                                            Fill="Black"
                                                            Stretch="Fill" />
                                                    </Button>
                                                    <!-- Apagar -->
                                                    <Button Background="Transparent"
                                                            Style="{StaticResource BotaoSemBorda}"
                                                            Click="BtnApagarPostagem_OnClick"
                                                            Tag="{Binding Id}">
                                                        <Path
                                                            Data="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z"
                                                            Width="24"
                                                            Height="24"
                                                            Fill="Black"
                                                            Stretch="Fill" />
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Button Width="56"
                Height="56"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,30,100"
                Cursor="Hand"
                Click="BtnPerfil_OnClick">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="ButtonBorder"
                                Background="#2563EB"
                                CornerRadius="28">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Direction="-90" ShadowDepth="3" Opacity="0.3" />
                            </Border.Effect>
                            <Path
                                Data="M367-527q-47-47-47-113t47-113q47-47 113-47t113 47q47 47 47 113t-47 113q-47 47-113 47t-113-47ZM160-160v-112q0-34 17.5-62.5T224-378q62-31 126-46.5T480-440q66 0 130 15.5T736-378q29 15 46.5 43.5T800-272v112H160Zm80-80h480v-32q0-11-5.5-20T700-306q-54-27-109-40.5T480-360q-56 0-111 13.5T260-306q-9 5-14.5 14t-5.5 20v32Zm296.5-343.5Q560-607 560-640t-23.5-56.5Q513-720 480-720t-56.5 23.5Q400-673 400-640t23.5 56.5Q447-560 480-560t56.5-23.5ZM480-640Zm0 400Z"
                                Height="24"
                                Width="24"
                                Fill="White"
                                Stretch="Fill" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button Width="56"
                Height="56"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,30,30"
                Cursor="Hand"
                Click="BtnNovoPost_OnClick">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="ButtonBorder"
                                Background="#2563EB"
                                CornerRadius="28">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Direction="-90" ShadowDepth="3" Opacity="0.3" />
                            </Border.Effect>
                            <Path
                                Data="M200-120q-33 0-56.5-23.5T120-200v-560q0-33 23.5-56.5T200-840h360v80H200v560h560v-360h80v360q0 33-23.5 56.5T760-120H200Zm120-160v-80h320v80H320Zm0-120v-80h320v80H320Zm0-120v-80h320v80H320Zm360-80v-80h-80v-80h80v-80h80v80h80v80h-80v80h-80Z"
                                Height="24"
                                Width="24"
                                Fill="White"
                                Stretch="Fill" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>